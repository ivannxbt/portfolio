# Admin credentials
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD_HASH=your_bcrypt_hashed_password   # generate with: node generate-hash.mjs

# NextAuth
NEXTAUTH_SECRET=your_secure_random_string          # generate with: openssl rand -base64 32
NEXTAUTH_URL=http://127.0.0.1:3000                 # required in production; set your canonical URL there
TRUST_PROXY_HEADERS=false                          # set true only behind a trusted reverse proxy
UPSTASH_REDIS_REST_URL=                            # optional shared rate limit store
UPSTASH_REDIS_REST_TOKEN=                          # optional shared rate limit store

# AI features — required for /api/chat and /api/summarize (Google Gemini)
GOOGLE_API_KEY=your_google_api_key

# Public site config (optional — fallback defaults are provided)
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_SUBSTACK_USERNAME=your_substack_username

# Database (optional — reserved for future use)
# DATABASE_URL=postgresql://user:pass@host/db
